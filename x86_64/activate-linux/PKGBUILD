pkgname=activate-linux
pkgver=1.1.0
_pkg="$pkgname-$pkgver"
pkgrel=3.1
pkgdesc="The \"Activate Windows\" watermark ported to Arch with Xlib and cairo in C"
arch=("x86_64")
url='https://github.com/MrGlockenspiel/activate-linux'
conflicts=('activate-linux-git' 'activate-linux-toggle')
makedepends=('make' 'clang' 'pkgconf')
depends=('cairo' 'libx11' 'libxi' 'libxt' 'libxrandr' 'libxfixes' 'libxinerama' 'wayland' 'wayland-protocols')
optdepends=('libconfig')
license=('GPL3')
install=.install
options=('!buildflags' '!makeflags' '!strip')
sha512sums=(
  'afb744971f3f3592601e4811f8956060112cc8d03f22c14e7eeb7b6104ecb4a6743d0d91f46df2c31b2d07dc97922d24ee7542fd601ef82c05d3ad2fd6a990d2'
  '629e2bba62f65db1351f0ae94e604b401c39021aaf429d26d31c3f984d05bdf06374797bec37416f119516d6d226599be04f68097659d19e05bf2dfb1971aba4'
)

source=(
  "activate-linux.service"
  "$_pkg.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz"
)

build() {
  cd "$srcdir/$_pkg"
  make #--silent
}

package() {
  install -Dm644 "$srcdir/$_pkg/LICENSE.md" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 "$srcdir/activate-linux.service" \
    "$pkgdir/usr/lib/systemd/user/activate-linux.service"
  install -Dm755 "$srcdir/$_pkg/activate-linux" \
    "$pkgdir/usr/bin/activate-linux"
}
